# LLM provider: "openai" or leave blank to auto-detect (uses Ollama if no OPENAI_API_KEY)
LLM_PROVIDER=openai

# OpenAI settings
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Ollama settings (only used when LLM_PROVIDER is not set and OPENAI_API_KEY is absent)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:instruct

# Persistent data directory (defaults to app/data when not set)
DATA_DIR=/data

# Path to the master responses CSV
OURDX_RESPONSES_CSV=/data/raw/ourdx_responses.csv
